{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "contacts": {
          "$contactId": {
            ".validate": "newData.hasChildren(['id', 'name', 'email'])"
          }
        }
      }
    },
    "friendRequests": {
      "$emailHash": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$requestId": {
          ".read": "auth != null",
          ".write": "auth != null && (!data.exists() || data.child('to').val() === auth.token.email || data.child('from').val() === auth.token.email)",
          ".validate": "newData.hasChildren(['type', 'from', 'to', 'ts']) && (newData.child('from').val() === auth.token.email || newData.child('to').val() === auth.token.email)"
        }
      }
    },
    "rooms": {
      "$roomCode": {
        "messages": {
          ".read":  "auth != null && root.child('rooms').child($roomCode).child('participants').child(auth.uid).val() === true",
          ".write": "auth != null && root.child('rooms').child($roomCode).child('participants').child(auth.uid).val() === true",
          "$msgId": {
            ".validate": "newData.hasChildren(['ts'])"
          }
        },
        "typing": {
          ".read":  "auth != null && root.child('rooms').child($roomCode).child('participants').child(auth.uid).val() === true",
          "$uid": {
            ".write":    "auth != null && auth.uid === $uid",
            ".validate": "newData.isBoolean()"
          }
        },
        "participants": {
          ".read":  "auth != null && data.child(auth.uid).val() === true",
          "$uid": {
            ".write":    "auth != null && auth.uid === $uid",
            ".validate": "newData.val() === true"
          }
        }
      }
    },
    "dms": {
      "$roomId": {
        "messages": {
          ".read":  "auth != null && root.child('dms').child($roomId).child('participants').child(auth.uid).val() === true",
          ".write": "auth != null && root.child('dms').child($roomId).child('participants').child(auth.uid).val() === true && root.child('dms').child($roomId).child('blockedSenders').child(auth.uid).val() !== true",
          "$msgId": {
            ".validate": "newData.hasChildren(['ts'])"
          }
        },
        "participants": {
          ".read":  "auth != null && data.child(auth.uid).val() === true",
          "$uid": {
            ".write":    "auth != null && auth.uid === $uid",
            ".validate": "newData.val() === true"
          }
        },
        "blockedSenders": {
          ".read": "auth != null && root.child('dms').child($roomId).child('participants').child(auth.uid).val() === true",
          "$blockedUid": {
            ".write": "auth != null && root.child('dms').child($roomId).child('participants').child(auth.uid).val() === true && auth.uid !== $blockedUid",
            ".validate": "newData.isBoolean() || !newData.exists()"
          }
        },
        "metadata": {
          ".read":  "auth != null",
          ".write": "auth != null && root.child('dms').child($roomId).child('participants').child(auth.uid).val() === true"
        },
        "typing": {
          ".read":  "auth != null && root.child('dms').child($roomId).child('participants').child(auth.uid).val() === true",
          "$uid": {
            ".write":    "auth != null && auth.uid === $uid",
            ".validate": "newData.isBoolean()"
          }
        },
        "emails": {
          ".read":  "auth != null",
          ".write": "auth != null && root.child('dms').child($roomId).child('participants').child(auth.uid).val() === true"
        }
      }
    },
    "invites": {
      "$email": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$roomId": {
          ".validate": "newData.val() === true"
        }
      }
    },
    "reports": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$reportId": {
        ".write": "auth != null && (!data.exists() || root.child('admins').child(auth.uid).val() === true)",
        ".validate": "newData.hasChildren(['reporterUid', 'reportedUid', 'reason', 'ts']) && newData.child('reporterUid').val() === auth.uid"
      }
    },
    "admins": {
      ".read": "auth != null && data.child(auth.uid).val() === true",
      "$uid": {
        ".write": false
      }
    }
  }
}
